# ── bank-sync configuration (NON-secret) ────────────────────────────────────
# Copy to .env and fill in. Bank passwords & the Supabase login are NOT here —
# they live in your OS keychain (set via `npm run setup`). Only non-secret
# runtime config belongs in this file.

# Supabase project (same values the dashboard uses).
# URL and anon (public) key are safe to keep here — the anon key is meant to be
# public and is already shipped in the web app. RLS protects your data.
SUPABASE_URL=https://jcyahiylnbfddzyqzbbg.supabase.co
SUPABASE_ANON_KEY=

# Local server settings for the "רענן מהבנקים" button.
PORT=4000

# Browser origins allowed to trigger /sync (comma-separated). Must include the
# live dashboard origin and your local dev origin. CORS + this allow-list are
# what stop a random website from triggering a sync.
ALLOWED_ORIGINS=https://transactions-dashboard-bfxn.onrender.com,http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Legacy fallback only — the accounts you sync are configured via `npm run setup`
# (each account has a provider + owner). This list is used only if no accounts
# have been set up yet.
PROVIDERS=leumi,discount,max,isracard

# Owner attribution for JOINT accounts (e.g. a shared bank account holding both
# salaries). JSON of owner → keywords matched in the description. Personal
# accounts always use the owner set in `npm run setup`. Defaults cover the
# salaries we've seen; override if needed, e.g.:
# OWNER_KEYWORDS={"מור":["מור","mor","בנק פועלים משכורת"],"שלי":["שלי","shelly","ישראכרט מש משכורת"]}

# How many months back to fetch each sync.
MONTHS_BACK=3

# Installments: by default each monthly charge is a separate line on its billing
# date (matches the card statement). Set to true to collapse a multi-payment
# purchase into one combined line on the purchase date.
# COMBINE_INSTALLMENTS=false

# Fetch the merchant's sector (ענף) per transaction from Isracard/Amex, stored
# as ענף_מקור and used to categorize merchants the keyword catalog misses.
# MAX sends its category for free on every sync; Isracard needs one extra
# request per transaction — slower and more likely to hit the anti-bot block,
# so enable deliberately (ideally one card per run, SHOW_BROWSER=true).
# ISRACARD_EXTRA_INFO=false

# Set to true if a provider needs interactive OTP/2FA — opens a real browser
# so you can enter the code. Keep false for headless background syncs.
SHOW_BROWSER=false

# Path to an installed Chrome/Chromium for the scraper. Leave unset on macOS to
# use Google Chrome at its default location (recommended — avoids the bundled
# Chromium "spawn Unknown system error -88" launch failure on Apple Silicon).
# Set this only if your browser lives elsewhere, e.g.:
#   CHROME_PATH=/Applications/Brave Browser.app/Contents/MacOS/Brave Browser
# CHROME_PATH=

# Debug only: with `npm run sync`, leave the scraper's browser window open after
# it finishes/fails so you can see what the bank showed (e.g. an OTP screen or
# error). Press Ctrl+C in the terminal to close. Don't use this with the server.
# KEEP_BROWSER_OPEN=false

# Income-month attribution for salaries that land near a month boundary.
#   next = late-month pay counts as the FOLLOWING month (default)
#   prev = early-month pay counts as the PREVIOUS month
#   none = leave salaries in the calendar month they were paid
# INCOME_SHIFT=next
# INCOME_SHIFT_DAY=25          # 'next': shift pay on/after this day; 'prev': on/before
# SALARY_MIN=4000             # a deposit at/above this (or matching a salary keyword) counts as salary
